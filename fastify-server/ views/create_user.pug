// views/create_user.pug
doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    title Создание пользователя
    style.
      body { font-family: sans-serif; }
      form { width: 50%; margin: 20px auto; padding: 20px; border: 1px solid #ccc; border-radius: 5px; }
      label { display: block; margin-bottom: 5px; }
      input[type="text"], input[type="email"] {
        width: calc(100% - 12px);
        padding: 8px;
        margin-bottom: 10px;
        border: 1px solid #ccc;
        border-radius: 3px;
      }
      button {
        padding: 10px 15px;
        background-color: #4CAF50;
        color: white;
        border: none;
        border-radius: 3px;
        cursor: pointer;
      }
      a { display: block; text-align: center; margin-top: 15px; }
      
  body
    h1 Создание нового пользователя

    form(method="POST" action="/users")
      div
        label(for="name") Имя:
        input(type="text" id="name" name="name" required)
      div
        label(for="email") Email:
        input(type="email" id="email" name="email" required)
      
      button(type="submit") Создать пользователя

    a(href="/users") Вернуться к списку
