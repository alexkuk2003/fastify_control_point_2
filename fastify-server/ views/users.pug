// views/users.pug
doctype html
html(lang="ru")
  head
    meta(charset="UTF-8")
    title Список пользователей
    style.
      body { font-family: sans-serif; }
      table { border-collapse: collapse; width: 80%; margin: 20px auto; }
      th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
      th { background-color: #f2f2f2; }
      a { margin: 10px auto; display: block; width: 200px; text-align: center; }

  body
    h1 Список пользователей

    if users && users.length > 0
      table
        thead
          tr
            th ID
            th Имя
            th Email
        tbody
          each user in users
            tr
              td #{user.id}
              td #{user.name}
              td #{user.email}
    else
      p Нет пользователей для отображения.

    a(href="/users/create") Добавить нового пользователя
